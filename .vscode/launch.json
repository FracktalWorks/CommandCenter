{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gateway (uvicorn, reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["gateway.main:app", "--reload", "--host", "0.0.0.0", "--port", "8080"],
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Reconciler (one-shot)",
      "type": "debugpy",
      "request": "launch",
      "module": "reconciler.main",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "justMyCode": false
    }
  ]
}
