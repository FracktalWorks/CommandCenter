# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.uv-cache/
dist/
build/
# Re-include Next.js app route directories named "build" inside src/app
!workbench/control_plane/src/app/build/
!workbench/control_plane/src/app/build/**

# Env / secrets
.env
.env.*
!.env.example
infra/.env
infra/litellm/litellm.env   # Auto-generated by deploy.sh — contains real keys
infra/litellm/tier_overrides.yaml  # Settings UI tier changes — survives deploys
*.pem
*.key
secrets/

# Local reference checkouts (e.g. upstream inbox-zero for parity work)
reference/

# IDE
.vscode/mcp.json
.idea/
*.swp
.DS_Store

# Tests / cov
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / workbench
node_modules/
.next/
out/

# Data / runtime
*.log
data/
logs/
.tmp/
tmp/

# Docker volumes (if mounted locally)
infra/volumes/

# CodeGraph — per-checkout local symbol index (dev-velocity tooling, Phase 2).
# The .mcp.json + codegraph.json config IS committed; the index is not.
.codegraph/
.codegraph.db
codegraph.db

# Theia IDE (old PRD - ADR-014 removed)
ide/
.vps

# Playwright transient artifacts
/test-results/
workbench/control_plane/test-results/

# Local agent configuration and observation logs
.claude/
skill-observations/

# Runtime caches / secrets / junk that must never be committed (foundation audit F2).
# .zoho_token_cache.json is regenerated at runtime by ingestion/sources/zoho/client.py.
*.pid
*.bak
*_dump.bak
*token_cache*.json
.zoho_token_cache.json
