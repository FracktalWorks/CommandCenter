[Unit]
Description=CommandCenter Gateway (FastAPI)
After=network-online.target acb.service
Wants=network-online.target
Requires=acb.service

[Service]
Type=simple
User=acb
WorkingDirectory=/opt/acb/app
Environment=PATH=/home/acb/.local/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=/opt/acb/app/.env
ExecStart=/home/acb/.local/bin/uv run uvicorn gateway.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
