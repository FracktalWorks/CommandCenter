# ====== AI Company Brain — environment template ======
# Copy to .env (gitignored) and fill in real values. Never commit .env.

# --- LLM provider keys (used by gateway via litellm SDK) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GITHUB_TOKEN=

# --- Note Taker STT (spec: ai-company-brain/specs/note_taker_app.md §3.4) ---
# Transcription routes through the platform's LiteLLM plumbing: the model is the
# `tier-stt` tier (infra/litellm/config.yaml, editable in Settings → Models),
# resolved and keyed exactly like the chat tiers. Default: groq/whisper-large-v3-turbo.
# Optional override — a tier alias or a concrete provider/model (e.g. openai/whisper-1):
NOTES_STT_MODEL=
# Deepgram — the paid STT provider that NAMES SPEAKERS (diarization). Set this,
# then pick a Deepgram model (nova-3 / nova-2) for the STT tier in Settings → Models.
# Live captions during recording also use this key (browser-direct via a
# short-lived token the gateway mints) — the master key needs key-management
# scope for that; without it, recording still works via the batch path.
DEEPGRAM_API_KEY=
# Optional — skip a Deepgram /projects lookup when minting live-caption tokens.
DEEPGRAM_PROJECT_ID=
# Where meeting audio lands on disk (relative to the gateway working dir).
NOTES_MEDIA_DIR=data/notes_media

# --- Local inference (vLLM) ---
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=Qwen/Qwen3-8B-Instruct

# --- Gateway LLM routing (via litellm SDK directly — no separate proxy) ---
LITELLM_MASTER_KEY=sk-local-dev-change-me
LITELLM_BASE_URL=http://127.0.0.1:8080

# --- Postgres (entity graph + pgvector + AGE) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=acb
POSTGRES_USER=acb
POSTGRES_PASSWORD=acb_dev_change_me
DATABASE_URL=postgresql+psycopg://acb:acb_dev_change_me@localhost:5432/acb

# --- Redis (event bus + GPTCache backing store) ---
REDIS_URL=redis://localhost:6379/0

# --- Mem0 — episodic memory (per-user cross-session facts) ---
# Requires: Postgres + pgvector (mem0ai creates its own table automatically).
# Set to true to enable automatic memory extraction and context injection.
MEM0_ENABLED=false

# --- Graphiti — bi-temporal knowledge graph (entity timelines) ---
# Requires: Neo4j running (docker compose --profile memory up -d neo4j).
# Extracts time-stamped entity facts from conversations and ingestion events.
GRAPHITI_ENABLED=false
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Langfuse (self-hosted observability) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Source-of-truth systems ---
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_WEBHOOK_SECRET=

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_REGION=in

ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# --- Google Workspace (Gmail + Calendar via DWD) ---
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-sa.json
GOOGLE_WORKSPACE_DOMAIN=fracktal.in
GOOGLE_PUBSUB_TOPIC=

# --- Email OAuth (Gmail + Microsoft 365 individual OAuth) ---
# Gmail OAuth 2.0 — requires a Google Cloud project with Gmail API enabled
# Redirect URI: https://<your-domain>/email/oauth/gmail/callback
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Microsoft 365 OAuth 2.0 — requires an Azure AD app registration
# Redirect URI: https://<your-domain>/email/oauth/microsoft/callback
MSFT_OAUTH_CLIENT_ID=
MSFT_OAUTH_CLIENT_SECRET=

# --- Inbound email (aiosmtpd SMTP receiver) ---
# SMTP server for receiving inbound emails directly (free, no vendor needed).
# Point your domain's MX record or email forwarding at this host:port.
EMAIL_INBOUND_HOST=127.0.0.1
EMAIL_INBOUND_PORT=10025
EMAIL_INBOUND_ACCOUNT_ID=

# --- Background email sync scheduler ---
# Set to true to auto-start per-account sync loops on gateway startup.
# When false, sync only runs on manual POST /email/sync trigger.
EMAIL_BACKGROUND_SYNC_ENABLED=true

# --- WhatsApp Business Cloud API ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Gateway / auth ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_SESSION_SECRET=change-me-dev-only
GOOGLE_SSO_CLIENT_ID=
GOOGLE_SSO_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=fracktal.in
# Internal service token — shared secret between Next.js proxy and gateway.
# Must match on both sides.  Falls back to LITELLM_MASTER_KEY in dev.
GATEWAY_INTERNAL_TOKEN=
# Comma-separated list of executive emails for role assignment.
# Everyone else defaults to "employee".
EXECUTIVE_EMAILS=

# --- VPS SSH access (for cloud agents to manage the VPS directly) ---
# VPS_SSH_KEY: base64-encoded private key — generate with: base64 -w0 ~/.ssh/your_key
VPS_HOST=
VPS_USER=root
VPS_SSH_PORT=22
VPS_PASSWORD=
VPS_SSH_KEY=

# --- Runtime ---
ACB_ENV=dev
LOG_LEVEL=INFO

# ====== Phase 0.5 — Skill Workbench ======

# --- OpenHands self-hosted sandbox (deploy/openhands/docker-compose.yml) ---
OPENHANDS_PORT=3000
OPENHANDS_DEFAULT_MODEL=tier-balanced
GITHUB_PAT=

# --- Control Plane (workbench/control_plane, Next.js on :3001) ---
# Path overrides (defaults resolve to ./skills relative to the control plane cwd)
SKILLS_ROOT=
# URLs surfaced into the browser via NEXT_PUBLIC_*
NEXT_PUBLIC_OPENHANDS_URL=http://localhost:3000

# NextAuth v5 (Google SSO restricted to @fracktal.in). Leave blank in dev to
# disable auth entirely; set all three to enable.  In production, AUTH_SECRET
# must be a strong random string (≥ 32 chars).
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_ALLOWED_DOMAIN=fracktal.in

# Gateway URL for Next.js API proxy routes.
GATEWAY_BASE_URL=http://127.0.0.1:8000

# Gateway /v1 endpoint for LLM calls (uses litellm SDK, NOT a separate proxy)
COPILOT_LLM_BASE_URL=http://127.0.0.1:8080/v1
COPILOT_LLM_API_KEY=
# Copilot CLI's own model env. MUST be a valid gateway tier alias
# (tier-fast|tier-balanced|tier-powerful) — never a bare "tierN-provider" name,
# which no tier resolves to. App agents/chats use COPILOT_CHAT_MODEL below; this
# only affects native Copilot CLI sessions. Keep the two consistent.
COPILOT_MODEL=tier-balanced

# Default model for all Copilot SDK agents/chats (LiteLLM gateway tier alias).
COPILOT_CHAT_MODEL=tier-balanced
# BYOK-by-default: route EVERY Copilot SDK agent through the LiteLLM gateway and
# normalize bare model names (e.g. an .agent.md "claude-sonnet-4-5") to
# COPILOT_CHAT_MODEL. Set false to let bare names hit api.githubcopilot.com.
COPILOT_BYOK_DEFAULT=true
COPILOTKIT_TELEMETRY_DISABLED=true

# Default output-token ceiling applied by the gateway's /v1 endpoint whenever a
# caller omits max_tokens. THIS is the real output cap for the whole platform:
# /v1 is the choke point every agent runtime POSTs through, and the Copilot SDK
# never sends max_tokens (its wire protocol has no such field). Raise this if an
# agent's output — or a long tool-call argument — is being cut off mid-way
# (symptom: a tool call fails with "Unterminated string in JSON at position N",
# or a turn ends with no text). Code default: 32000.
#GATEWAY_DEFAULT_MAX_OUTPUT_TOKENS=32000

# NOTE: COPILOT_MAX_OUTPUT_TOKENS is a NO-OP and is kept only for
# backward-compat. The Copilot SDK's create/resume-session wire protocol has no
# max_tokens field, so neither this env var nor the SessionConfig max_tokens we
# set ever reaches the model. Use GATEWAY_DEFAULT_MAX_OUTPUT_TOKENS above.
#COPILOT_MAX_OUTPUT_TOKENS=  # dead knob — does nothing

# Infinite-session compaction policy for Copilot SDK agents.
# default: disabled for BYOK models (backend window estimate is wrong),
#          relaxed thresholds (bg=0.92, buf=0.99) for Copilot-native models.
# off: disable backend compaction entirely (use when C2 assembly is the sole
#      context manager).
# default: leave SDK defaults untouched (0.80/0.95 — not recommended for BYOK).
#COPILOT_INFINITE_SESSIONS=
#COPILOT_COMPACTION_THRESHOLD=0.92
#COPILOT_BUFFER_THRESHOLD=0.99

# workspace_root for agent config.json: set $COMMANDCENTER_ROOT in your .env
# to point a development agent at the CommandCenter repo so shell commands
# and file edits run in the right directory.
#COMMANDCENTER_ROOT=/path/to/CommandCenter

# ── Telemetry (HH-3) ────────────────────────────────────────────────────────
# When set, LiteLLM registers its OpenTelemetry callback and exports LLM-call
# traces there (e.g. http://127.0.0.1:4318). Leave unset to export nothing.
# Re-enable MAF's own instrumentation with ENABLE_INSTRUMENTATION=1 only after
# this endpoint exists.
#OTEL_EXPORTER_OTLP_ENDPOINT=
# Per-LLM-call token/cache usage is always logged (acb_llm.usage); set to 1 to
# also append an audit_event row per call.
LLM_USAGE_AUDIT=0
