# LiteLLM Proxy Environment
# ===========================
# This file is auto-generated by deploy.sh from /opt/acb/app/.env.
# Keep it out of version control — it contains real API keys.
#
# IMPORTANT: DATABASE_URL MUST use plain `postgresql://` format.
# LiteLLM uses Prisma internally, which rejects the `postgresql+psycopg://`
# format that SQLAlchemy/Alembic uses.  Do NOT copy DATABASE_URL from .env.
# ----------------------------------------------------------------

DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
GITHUB_TOKEN=
LITELLM_MASTER_KEY=

# Prisma-compatible format (NO +psycopg suffix):
DATABASE_URL=postgresql://acb:CHANGE_ME@localhost:5432/litellm_proxy
